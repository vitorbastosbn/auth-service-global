### Register
POST http://localhost:8080/api/v1/auth/register
Content-Type: application/json

{
  "name": "John Doe",
  "email": "john@example.com",
  "password": "Test@1234"
}

### Login
POST http://localhost:8080/api/v1/auth/login
Content-Type: application/json

{
  "email": "john@example.com",
  "password": "Test@1234"
}

### Refresh Token
POST http://localhost:8080/api/v1/auth/refresh
Content-Type: application/json

{
  "refreshToken": "{{refreshToken}}"
}

### Logout
POST http://localhost:8080/api/v1/auth/logout
Content-Type: application/json

{
  "refreshToken": "{{refreshToken}}"
}

### Validate Token
POST http://localhost:8080/api/v1/auth/validate
Content-Type: application/json

{
  "token": "{{accessToken}}"
}

### Get current user
GET http://localhost:8080/api/v1/users/me
Authorization: Bearer {{accessToken}}

### Update current user
PUT http://localhost:8080/api/v1/users/me
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "name": "John Updated"
}

### Change password
PATCH http://localhost:8080/api/v1/users/me/password
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "currentPassword": "Test@1234",
  "newPassword": "NewTest@1234"
}

### Delete current user
DELETE http://localhost:8080/api/v1/users/me
Authorization: Bearer {{accessToken}}

### Admin - List all users
GET http://localhost:8080/api/v1/admin/users
Authorization: Bearer {{adminAccessToken}}

### Admin - Update user role
PATCH http://localhost:8080/api/v1/admin/users/{{userId}}/role
Authorization: Bearer {{adminAccessToken}}
Content-Type: application/json

{
  "role": "ADMIN"
}

### Admin - Update user status
PATCH http://localhost:8080/api/v1/admin/users/{{userId}}/status
Authorization: Bearer {{adminAccessToken}}
Content-Type: application/json

{
  "active": false
}

### Health Check
GET http://localhost:8080/actuator/health
